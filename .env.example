APP_ENV=local
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

LLM_PROVIDER=mock

GIGACHAT_API_KEY=change_me
GIGACHAT_MODEL=change_me
GIGACHAT_BASE_URL=change_me

YANDEX_API_KEY=change_me
YANDEX_FOLDER_ID=change_me
